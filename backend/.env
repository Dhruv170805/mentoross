# ══════════════════════════════════════════════════
# MentorOS Backend — Environment Variables
# ══════════════════════════════════════════════════

# ── App ──────────────────────────────────────────
APP_NAME=MentorOS API
APP_VERSION=3.0.0
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Security ─────────────────────────────────────
SECRET_KEY=f3d661b1e456769701df338f1f5bfaeddb1f551807888788da000e25be8abb84
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000", "null"]

# ── Database ──────────────────────────────────────
# MongoDB Atlas
MONGODB_URI=mongodb+srv://user_data:Data1234@cluster0.qel9ki3.mongodb.net/?appName=Cluster0
DATABASE_NAME=mentoross

# ── Redis (optional - for caching) ───────────────
REDIS_URL=redis://localhost:6379/0

# ── Custom AI ────────────────────────────────────
AI_MAX_TOKENS=2048

# ── Vector Store ─────────────────────────────────
VECTOR_STORE_PATH=./data/vector.index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_MINUTE=10

# ── Scheduler ────────────────────────────────────
REMINDER_INTERVAL_MINUTES=60
